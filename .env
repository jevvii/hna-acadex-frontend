# ============================================
# HNA Acadex Frontend - Environment Configuration
# ============================================
#
# IMPORTANT: This file should NEVER be committed to git!
# Use .env.example as a template
#

# ============================================
# PRODUCTION (Active)
# ============================================
EXPO_PUBLIC_API_URL=https://hna-acadex-backend.onrender.com/api

# ============================================
# LOCAL DEVELOPMENT (Comment out production above, uncomment below)
# ============================================
# Android Emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api
# iOS Simulator: EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api
# Physical Device: EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:8000/api

# ============================================
# DEV NOTIFICATION TESTING (Development only)
# ============================================
# EXPO_PUBLIC_DEV_NOTIFICATIONS_ENABLED=1