# ============================================
# HNA Acadex Frontend - Environment Configuration
# ============================================
#
# Choose your environment by uncommenting the appropriate API URL:
#

# LOCAL DEVELOPMENT (Android Emulator) - RECOMMENDED
# Use this when running the backend with: python manage.py runserver 0.0.0.0:8000
# The Android emulator uses 10.0.2.2 to reach the host machine's localhost
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api

# LOCAL DEVELOPMENT (iOS Simulator)
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# LOCAL DEVELOPMENT (Physical Device)
# Find your LAN IP with: ipconfig (Windows) or ifconfig/ip (Mac/Linux)
# EXPO_PUBLIC_API_URL=http://192.168.1.xxx:8000/api

# PRODUCTION
# EXPO_PUBLIC_API_URL=https://hna-acadex-backend.onrender.com/api

# ============================================
# DEV NOTIFICATION TESTING
# ============================================
# Enable push notification simulation on emulators/simulators.
# When enabled, bypasses Device.isDevice check and generates mock tokens.
# This allows testing notification flows without a real device.
# WARNING: Only use in development! Tokens won't work with real FCM/APNs.
# EXPO_PUBLIC_DEV_NOTIFICATIONS_ENABLED=1

# ============================================
# QUICK REFERENCE
# ============================================
#
# Backend Local URLs:
#   - Your computer: http://localhost:8000/api
#   - Android emulator: http://10.0.2.2:8000/api
#   - iOS simulator: http://127.0.0.1:8000/api
#   - Physical device: http://<YOUR_LAN_IP>:8000/api
#
# To start the backend for local development:
#   cd hna-acadex-backend
#   source .venv/bin/activate  # if using venv
#   python manage.py runserver 0.0.0.0:8000
#
# Or use the dev script:
#   ./dev.sh